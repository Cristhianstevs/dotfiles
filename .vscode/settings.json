{
   // FERRAMENTAS E EXTENSÕES
   "github.copilot.enable": {
      "*": false, // Desativa global
      "plaintext": false, // Desativa em texto
      "markdown": false, // Desativa em MD
      "scminput": false // Desativa no Git
   },
   "gitlens.ai.model": "vscode", // IA base
   "gitlens.ai.vscode.model": "copilot:gpt-4.1", // Força GPT-4
   "liveServer.settings.donotVerifyTags": true, // Sem alertas de HTML vazio

   // INTERFACE DO EDITOR
   "window.customTitleBarVisibility": "windowed", // Barra de título nativa
   "explorer.compactFolders": false, // Desativa pastas em linha
   "workbench.startupEditor": "newUntitledFile", // Inicia com arquivo vazio
   "workbench.tree.indent": 16, // Recuo lateral de pastas
   "breadcrumbs.enabled": false, // Oculta caminho no topo

   // FONTE E ESTILO
   "editor.fontFamily": "JetBrains Mono", // Fonte oficial
   "editor.fontSize": 14, // Tamanho
   "editor.lineHeight": 1.8, // Espaçamento entre linhas
   "editor.fontLigatures": true, // Ativa setas bonitas (=>)
   "editor.renderLineHighlight": "gutter", // Destaca número da linha
   "editor.wordWrap": "on", // Quebra de linha visual

   // INDENTAÇÃO BASE
   "editor.tabSize": 3, // Tamanho do recuo
   "editor.insertSpaces": true, // Usa Espaços em vez de Tabs
   "editor.detectIndentation": false, // Força suas regras sempre
   "files.trimTrailingWhitespace": true, // Limpa espaços finais ao salvar

   // COMPORTAMENTO DE SALVAMENTO
   "files.autoSave": "afterDelay", // Salva sozinho ao parar de digitar
   "editor.formatOnSave": false, // Formatação apenas manual (Alt+Shift+F)
   "editor.formatOnType": false, // Sem formatar enquanto digita

   // SEGURANÇA JSON
   // Domínios confiáveis para download de esquemas (evita pop-ups)
   "json.schemaDownload.trustedDomains": {
      "https://schemastore.azurewebsites.net/": true,
      "https://raw.githubusercontent.com/": true,
      "https://www.schemastore.org/": true,
      "https://json.schemastore.org/": true,
      "https://json-schema.org/": true,
      "https://biomejs.dev": true
   },

   // DOMÍNIO DO BIOME
   "editor.defaultFormatter": "biomejs.biome", // Formatador global

   // Força o Biome por linguagem
   "[javascript]": { "editor.defaultFormatter": "biomejs.biome" },
   "[typescript]": { "editor.defaultFormatter": "biomejs.biome" },
   "[javascriptreact]": { "editor.defaultFormatter": "biomejs.biome" },
   "[typescriptreact]": { "editor.defaultFormatter": "biomejs.biome" },
   "[json]": { "editor.defaultFormatter": "biomejs.biome" },
   "[jsonc]": { "editor.defaultFormatter": "biomejs.biome" },
   "[html]": { "editor.defaultFormatter": "biomejs.biome" },
   "[css]": { "editor.defaultFormatter": "biomejs.biome" }
}
